{
  "name": "portfolio-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "config": "node scripts/set-env.js",
    "start": "npm run config && ng serve",
    "build": "npm run config && ng build",
    "build:prod": "npm run config && ng build --configuration production",
    "build:staging": "npm run config && ng build --configuration staging",
    "watch": "npm run config && ng build --watch --configuration development",
    "test": "ng test",
    "docker:build": "docker build -t portfolio-angular:latest .",
    "docker:run": "docker run --name portfolio-angular -p 8080:8080 --env-file .env portfolio-angular:latest",
    "docker:compose": "docker-compose up --build"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "dotenv": "^16.4.7",
    "fast-check": "^4.6.0",
    "firebase": "^12.10.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "firebase-admin": "^13.7.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
